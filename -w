                        <div><dt class="text-[11px] text-gray-400 font-medium font-mono" x-text="key"></dt><dd class="text-sm text-gray-900 mt-0.5" x-text="Array.isArray(val) ? val.join(', ') : typeof val === 'boolean' ? (val ? 'Yes' : 'No') : val"></dd></div>
