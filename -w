<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Keystone Portal — Infrastructure Platform</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
          colors: {
            brand: {
              50:'#eef2ff',100:'#e0e7ff',200:'#c7d2fe',300:'#a5b4fc',
              400:'#818cf8',500:'#6366f1',600:'#4f46e5',700:'#4338ca',
              800:'#3730a3',900:'#312e81',950:'#1e1b4b',
            }
          }
        }
      }
    }
  </script>
  <style>
    [x-cloak]{display:none!important}
    .badge-pending{background:#fef3c7;color:#92400e}
    .badge-plan_running{background:#dbeafe;color:#1e40af}
    .badge-plan_failed{background:#fee2e2;color:#991b1b}
    .badge-awaiting_approval{background:#e0e7ff;color:#3730a3}
    .badge-provisioning{background:#cffafe;color:#155e75}
    .badge-deployed{background:#d1fae5;color:#065f46}
    .badge-failed{background:#fee2e2;color:#991b1b}
    .badge-destroyed{background:#f3f4f6;color:#374151}
    .badge-cancelled{background:#f3f4f6;color:#6b7280}
    .badge-pending_approval{background:#fef3c7;color:#92400e}
    .badge-approved{background:#dbeafe;color:#1e40af}
    .badge-active{background:#d1fae5;color:#065f46}
    .badge-suspended{background:#fee2e2;color:#991b1b}
    .badge-closed{background:#f3f4f6;color:#6b7280}
    .nav-active{background:linear-gradient(135deg,rgba(99,102,241,.15),rgba(139,92,246,.1));color:#6366f1;border-left:3px solid #6366f1}
    .nav-item{transition:all .15s ease}
    .nav-item:hover{background:rgba(99,102,241,.08)}
    ::-webkit-scrollbar{width:6px}
    ::-webkit-scrollbar-track{background:transparent}
    ::-webkit-scrollbar-thumb{background:#c7d2fe;border-radius:3px}
    .fade-in{animation:fadeIn .3s ease-out}
    @keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
    .login-bg{background:linear-gradient(135deg,#1e1b4b 0%,#312e81 25%,#4338ca 50%,#6366f1 75%,#818cf8 100%)}
    .glass{background:rgba(255,255,255,.08);backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,.12)}
    .toast{animation:slideIn .3s ease-out,fadeOut .3s ease-in 2.7s forwards}
    @keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
    @keyframes fadeOut{to{opacity:0;transform:translateY(-10px)}}
    @keyframes countUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
    .count-up{animation:countUp .5s ease-out forwards}
    @keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.4}}
    .pulse-dot{animation:pulse-dot 2s ease-in-out infinite}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-20px)}}
    .float-slow{animation:float 6s ease-in-out infinite}
    .float-med{animation:float 4s ease-in-out infinite}
    .float-fast{animation:float 3s ease-in-out infinite}
    @media(max-width:1023px){.sidebar-hidden{transform:translateX(-100%)}}
    /* Kubernetes theme */
    .k8s-gradient{background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"),linear-gradient(135deg,#1e1b4b 0%,#312e81 25%,#3730a3 50%,#4338ca 75%,#4f46e5 100%)}
    .k8s-pattern{}
    @keyframes spinSlow{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
    .k8s-spin{animation:spinSlow 20s linear infinite}
    @keyframes k8sPulse{0%,100%{opacity:.6}50%{opacity:1}}
    .k8s-pulse{animation:k8sPulse 3s ease-in-out infinite}
    .upgrade-input{transition:all .2s;border:2px solid #e5e7eb;border-radius:.75rem;padding:.5rem .75rem;font-size:.875rem;font-family:'Inter',monospace;background:#f9fafb}
    .upgrade-input:focus{outline:none;border-color:#326ce5;box-shadow:0 0 0 3px rgba(50,108,229,.15);background:white}
    .upgrade-input:disabled{opacity:.5;cursor:not-allowed}
    .version-badge{font-family:'Inter',monospace;letter-spacing:.02em}
  </style>
</head>
<body class="h-full font-sans" x-data="app()" x-init="init()" x-cloak>

  <!-- ═══════════════════════════ TOAST NOTIFICATIONS ═══════════════════════════ -->
  <div class="fixed top-4 right-4 z-50 space-y-2">
    <template x-for="(toast, idx) in toasts" :key="idx">
      <div class="toast flex items-center gap-3 px-5 py-3.5 rounded-2xl shadow-xl text-sm font-medium max-w-sm"
           :class="toast.type === 'success' ? 'bg-emerald-600 text-white' : toast.type === 'error' ? 'bg-red-600 text-white' : 'bg-brand-600 text-white'">
        <svg x-show="toast.type==='success'" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
        <svg x-show="toast.type==='error'" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" /></svg>
        <span x-text="toast.message"></span>
      </div>
    </template>
  </div>

  <!-- ═══════════════════════════ LOGIN PAGE ═══════════════════════════ -->
  <template x-if="!authenticated">
    <div class="h-full login-bg flex items-center justify-center p-4">
      <!-- Animated floating shapes -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/4 left-1/6 w-72 h-72 bg-brand-400/10 rounded-full blur-3xl float-slow"></div>
        <div class="absolute bottom-1/4 right-1/6 w-96 h-96 bg-violet-400/10 rounded-full blur-3xl float-med"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-300/5 rounded-full blur-3xl float-fast"></div>
        <div class="absolute top-10 right-1/4 w-40 h-40 bg-pink-400/5 rounded-full blur-2xl float-med"></div>
      </div>

      <div class="relative w-full max-w-5xl fade-in">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

          <!-- Left side — Feature showcase -->
          <div class="hidden lg:block text-white space-y-8">
            <div>
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white/10 backdrop-blur-xl border border-white/20 shadow-2xl mb-6">
                <svg class="w-9 h-9 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
                </svg>
              </div>
              <h1 class="text-4xl font-extrabold tracking-tight leading-tight">Keystone<br/><span class="text-brand-200 font-light">Infrastructure Platform</span></h1>
              <p class="text-brand-200/80 mt-3 text-base leading-relaxed max-w-md">Self-service infrastructure provisioning with GitOps workflows. Request, review, and deploy — all from a Jira form.</p>
            </div>

            <div class="space-y-4">
              <div class="flex items-start gap-4 bg-white/5 backdrop-blur-sm rounded-2xl p-4 border border-white/10 hover:bg-white/10 transition-all">
                <div class="w-10 h-10 rounded-xl bg-emerald-500/20 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z"/></svg>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-white">13 Resource Types</h3>
                  <p class="text-xs text-brand-200/70 mt-0.5">EKS, RDS, S3, Lambda, MSK, DynamoDB, SRE Onboarding, and more</p>
                </div>
              </div>
              <div class="flex items-start gap-4 bg-white/5 backdrop-blur-sm rounded-2xl p-4 border border-white/10 hover:bg-white/10 transition-all">
                <div class="w-10 h-10 rounded-xl bg-sky-500/20 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-sky-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"/></svg>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-white">GitOps Workflow</h3>
                  <p class="text-xs text-brand-200/70 mt-0.5">Jira form &rarr; Terraform PR &rarr; Plan &rarr; Review &rarr; Deploy automatically</p>
                </div>
              </div>
              <div class="flex items-start gap-4 bg-white/5 backdrop-blur-sm rounded-2xl p-4 border border-white/10 hover:bg-white/10 transition-all">
                <div class="w-10 h-10 rounded-xl bg-amber-500/20 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-amber-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-white">Account Vending</h3>
                  <p class="text-xs text-brand-200/70 mt-0.5">Automated AWS account provisioning with security baselines</p>
                </div>
              </div>
              <div class="flex items-start gap-4 bg-white/5 backdrop-blur-sm rounded-2xl p-4 border border-white/10 hover:bg-white/10 transition-all">
                <div class="w-10 h-10 rounded-xl bg-violet-500/20 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-violet-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-white">Central Observability</h3>
                  <p class="text-xs text-brand-200/70 mt-0.5">SRE onboarding with VPC peering, Prometheus, OTel, and Grafana</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Right side — Login card -->
          <div class="w-full max-w-md mx-auto lg:mx-0">
            <!-- Mobile logo (hidden on desktop) -->
            <div class="text-center mb-8 lg:hidden">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white/10 backdrop-blur-xl border border-white/20 shadow-2xl mb-5">
                <svg class="w-9 h-9 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
                </svg>
              </div>
              <h1 class="text-3xl font-bold text-white tracking-tight">Keystone</h1>
              <p class="text-brand-200 text-sm mt-1 tracking-wide">Infrastructure Platform Portal</p>
            </div>

            <!-- Login card -->
            <div class="glass rounded-3xl p-8 shadow-2xl">
          <div x-show="loginMode === 'login'">
            <h2 class="text-xl font-semibold text-white mb-1">Welcome back</h2>
            <p class="text-brand-200 text-sm mb-6">Sign in to manage your infrastructure</p>

            <form @submit.prevent="handleLogin()">
              <div class="space-y-4">
                <div>
                  <label class="block text-xs font-semibold text-brand-200 uppercase tracking-wider mb-1.5">Email</label>
                  <input type="email" x-model="loginForm.email" required autocomplete="email"
                         class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/40 focus:border-brand-300 focus:ring-brand-300 focus:bg-white/15 transition-all text-sm"
                         placeholder="you@company.com" />
                </div>
                <div>
                  <label class="block text-xs font-semibold text-brand-200 uppercase tracking-wider mb-1.5">Password</label>
                  <input type="password" x-model="loginForm.password" required autocomplete="current-password"
                         class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/40 focus:border-brand-300 focus:ring-brand-300 focus:bg-white/15 transition-all text-sm"
                         placeholder="Enter your password" />
                </div>
                <div x-show="loginError" class="text-red-300 text-sm bg-red-500/20 border border-red-400/30 rounded-xl px-4 py-2.5" x-text="loginError"></div>
                <button type="submit" :disabled="loginLoading"
                        class="w-full py-3 px-4 bg-white text-brand-700 font-semibold rounded-xl hover:bg-brand-50 transition-all shadow-lg disabled:opacity-50 text-sm">
                  <span x-show="!loginLoading">Sign In</span>
                  <span x-show="loginLoading" class="flex items-center justify-center gap-2">
                    <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                    Signing in...
                  </span>
                </button>
              </div>
            </form>
            <p class="text-center text-brand-300 text-xs mt-5">Don't have an account? <button @click="loginMode='register'" class="text-white font-semibold hover:underline">Create one</button></p>
          </div>

          <div x-show="loginMode === 'register'">
            <h2 class="text-xl font-semibold text-white mb-1">Create account</h2>
            <p class="text-brand-200 text-sm mb-6">Register to access the platform</p>

            <form @submit.prevent="handleRegister()">
              <div class="space-y-4">
                <div>
                  <label class="block text-xs font-semibold text-brand-200 uppercase tracking-wider mb-1.5">Full Name</label>
                  <input type="text" x-model="registerForm.full_name" required
                         class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/40 focus:border-brand-300 focus:ring-brand-300 focus:bg-white/15 transition-all text-sm"
                         placeholder="John Doe" />
                </div>
                <div>
                  <label class="block text-xs font-semibold text-brand-200 uppercase tracking-wider mb-1.5">Email</label>
                  <input type="email" x-model="registerForm.email" required
                         class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/40 focus:border-brand-300 focus:ring-brand-300 focus:bg-white/15 transition-all text-sm"
                         placeholder="you@company.com" />
                </div>
                <div>
                  <label class="block text-xs font-semibold text-brand-200 uppercase tracking-wider mb-1.5">Password</label>
                  <input type="password" x-model="registerForm.password" required minlength="6"
                         class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/40 focus:border-brand-300 focus:ring-brand-300 focus:bg-white/15 transition-all text-sm"
                         placeholder="Min 6 characters" />
                </div>
                <div x-show="loginError" class="text-red-300 text-sm bg-red-500/20 border border-red-400/30 rounded-xl px-4 py-2.5" x-text="loginError"></div>
                <button type="submit" :disabled="loginLoading"
                        class="w-full py-3 px-4 bg-white text-brand-700 font-semibold rounded-xl hover:bg-brand-50 transition-all shadow-lg disabled:opacity-50 text-sm">
                  <span x-show="!loginLoading">Create Account</span>
                  <span x-show="loginLoading" class="flex items-center justify-center gap-2">
                    <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                    Creating...
                  </span>
                </button>
              </div>
            </form>
            <p class="text-center text-brand-300 text-xs mt-5">Already have an account? <button @click="loginMode='login'" class="text-white font-semibold hover:underline">Sign in</button></p>
          </div>

          <!-- Demo hint -->
          <div class="mt-6 pt-5 border-t border-white/10">
            <div class="flex items-center gap-2 text-brand-300 text-[11px] mb-2">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" /></svg>
              Demo Credentials
            </div>
            <div class="bg-white/5 rounded-xl px-4 py-2.5 text-xs font-mono text-brand-100 space-y-0.5">
              <p>Email: <span class="text-white">admin@keystone.io</span></p>
              <p>Pass: &nbsp;<span class="text-white">admin123</span></p>
            </div>
          </div>
        </div>

        <p class="text-center text-brand-400/60 text-[11px] mt-6">&copy; 2026 Keystone Platform &bull; v4.0.0</p>
          </div>
        </div>
      </div>
    </div>
  </template>

  <!-- ═══════════════════════════ MAIN APP (AFTER LOGIN) ═══════════════════════════ -->
  <template x-if="authenticated">
    <div class="flex h-full bg-gray-50">

      <!-- Mobile overlay -->
      <div x-show="sidebarOpen" @click="sidebarOpen=false" class="fixed inset-0 bg-black/40 z-20 lg:hidden" x-transition.opacity></div>

      <!-- ─────────── Sidebar ─────────── -->
      <aside :class="sidebarOpen?'translate-x-0':'sidebar-hidden'" class="w-64 bg-white border-r border-gray-200 flex flex-col fixed inset-y-0 left-0 z-30 shadow-sm transition-transform lg:translate-x-0">
        <div class="h-16 flex items-center gap-3 px-5 border-b border-gray-100">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500 to-violet-600 flex items-center justify-center shadow-lg shadow-brand-200">
