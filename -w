                      <div><dt class="text-[11px] text-gray-400 font-medium">Target Repo</dt><dd class="text-sm font-mono text-gray-900 mt-0.5" x-text="detail.github_group+'/'+detail.github_repo"></dd></div>
                      <div><dt class="text-[11px] text-gray-400 font-medium">Branch</dt><dd class="text-sm font-mono text-gray-700 mt-0.5" x-text="detail.branch_name"></dd></div>
                      <div><dt class="text-[11px] text-gray-400 font-medium">Pull Request</dt><dd class="text-sm mt-0.5"><a :href="detail.pr_url" target="_blank" class="text-brand-600 hover:text-brand-800 font-medium inline-flex items-center gap-1">PR #<span x-text="detail.pr_number||'—'"></span> <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg></a></dd></div>
                      <div><dt class="text-[11px] text-gray-400 font-medium">Created</dt><dd class="text-sm text-gray-900 mt-0.5" x-text="formatDate(detail.created_at)"></dd></div>
