                    <span class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur px-3 py-1.5 rounded-lg border border-white/20"><svg class="w-3.5 h-3.5 text-amber-200" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>PDB + HPA + RBAC</span>
                  </div>
                </div>
              </div>

              <!-- ───── Onboarded Projects ───── -->
              <template x-if="argocdProjects.length > 0">
                <div class="rounded-2xl bg-white border border-gray-200/80 shadow-sm overflow-hidden">
                  <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                    <h3 class="text-sm font-semibold text-gray-800 flex items-center gap-2"><div class="w-1.5 h-4 rounded-full bg-orange-500"></div>Onboarded Projects</h3>
                    <span class="text-xs text-gray-400" x-text="argocdProjects.length + ' project(s)'"></span>
                  </div>
                  <div class="divide-y divide-gray-100">
                    <template x-for="proj in argocdProjects" :key="proj.jira_ticket_key">
                      <div class="p-5 hover:bg-gray-50/50 transition-colors">
                        <div class="flex items-center justify-between mb-3">
                          <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center" :class="proj.status==='deployed'?'bg-emerald-50':'bg-amber-50'">
                              <svg class="w-5 h-5" :class="proj.status==='deployed'?'text-emerald-600':'text-amber-600'" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 2.182a9.818 9.818 0 110 19.636 9.818 9.818 0 010-19.636zm4.91 5.455l-6.546 2.618L7.09 16.8l6.546-2.618 3.273-6.546z"/></svg>
                            </div>
                            <div>
                              <h4 class="text-sm font-bold text-gray-800" x-text="proj.project_name"></h4>
                              <p class="text-[11px] text-gray-400"><span x-text="proj.team_name"></span> &bull; <span x-text="proj.cluster_name"></span> &bull; <span class="font-mono" x-text="proj.jira_ticket_key"></span></p>
                            </div>
                          </div>
                          <div class="flex items-center gap-3">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[11px] font-bold"
                              :class="proj.status==='deployed'?'bg-emerald-50 text-emerald-700 border border-emerald-200':proj.status==='pending'?'bg-amber-50 text-amber-700 border border-amber-200':'bg-blue-50 text-blue-700 border border-blue-200'"
                              x-text="proj.status"></span>
                          </div>
                        </div>
                        <!-- Services grid -->
                        <div class="flex flex-wrap gap-2 mb-3">
                          <template x-for="svc in proj.services" :key="svc">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-[11px] font-medium bg-gray-100 text-gray-700 border border-gray-200">
                              <svg class="w-3 h-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/></svg>
                              <span x-text="svc"></span>
                            </span>
                          </template>
                        </div>
                        <div class="flex items-center gap-4 text-[11px] text-gray-400">
                          <span class="inline-flex items-center gap-1"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/></svg><span x-text="(proj.services?.length||0) + ' services'"></span></span>
                          <span class="inline-flex items-center gap-1"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L12 12.75 6.429 9.75M17.571 14.25l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25"/></svg><span x-text="(proj.environments?.length||0) + ' envs'"></span></span>
                          <span class="inline-flex items-center gap-1 font-semibold text-orange-500"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z"/></svg><span x-text="(proj.services?.length||0) * (proj.environments?.length||0) + ' total apps'"></span></span>
                          <span x-text="proj.deployed_at ? 'Deployed ' + formatDate(proj.deployed_at) : 'Created ' + formatDate(proj.created_at)"></span>
                        </div>
                      </div>
                    </template>
                  </div>
                </div>
              </template>

              <!-- ───── Cluster Selection + Onboarding Form ───── -->
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- EKS Clusters (eligible for ArgoCD) -->
                <div class="rounded-2xl bg-white border border-gray-200/80 shadow-sm overflow-hidden">
                  <div class="px-6 py-4 border-b border-gray-100">
                    <h3 class="text-sm font-semibold text-gray-800 flex items-center gap-2"><div class="w-1.5 h-4 rounded-full bg-blue-500"></div>Select EKS Cluster</h3>
                    <p class="text-[11px] text-gray-400 mt-0.5">Choose a deployed cluster to onboard for GitOps</p>
                  </div>
                  <div class="divide-y divide-gray-100 max-h-96 overflow-y-auto">
                    <template x-for="cl in argocdClusters" :key="cl.jira_ticket_key">
                      <button @click="selectClusterForArgocd(cl)" class="w-full p-4 text-left transition-colors" :class="cl.has_argocd?'opacity-50 cursor-not-allowed bg-gray-50':argocdForm.selectedCluster?.jira_ticket_key===cl.jira_ticket_key?'bg-orange-50 border-l-4 border-orange-500':'hover:bg-gray-50'">
                        <div class="flex items-center justify-between">
                          <div>
                            <h4 class="text-sm font-semibold text-gray-800" x-text="cl.cluster_name"></h4>
                            <p class="text-[11px] text-gray-400 mt-0.5"><span x-text="cl.team_name"></span> &bull; <span x-text="cl.environment"></span> &bull; <span class="font-mono" x-text="cl.jira_ticket_key"></span></p>
                          </div>
                          <div class="text-right">
                            <span x-show="cl.has_argocd" class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-bold bg-emerald-100 text-emerald-700 border border-emerald-200">Onboarded</span>
                            <span x-show="!cl.has_argocd" class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-bold bg-blue-100 text-blue-700 border border-blue-200">Available</span>
                            <p class="text-[10px] text-gray-400 mt-0.5 font-mono" x-text="'v' + cl.cluster_version"></p>
                          </div>
                        </div>
                      </button>
                    </template>
                    <div x-show="argocdClusters.length===0" class="text-sm text-gray-400 text-center py-8">No deployed EKS clusters found</div>
                  </div>
                </div>

                <!-- Onboarding Form -->
                <div class="rounded-2xl bg-white border border-gray-200/80 shadow-sm overflow-hidden">
                  <div class="px-6 py-4 border-b border-gray-100">
                    <h3 class="text-sm font-semibold text-gray-800 flex items-center gap-2"><div class="w-1.5 h-4 rounded-full bg-orange-500"></div>Onboarding Configuration</h3>
                    <p class="text-[11px] text-gray-400 mt-0.5" x-text="argocdForm.selectedCluster ? 'Configure GitOps for ' + argocdForm.selectedCluster.cluster_name : 'Select a cluster to begin'"></p>
                  </div>
                  <div class="p-6" x-show="argocdForm.selectedCluster">
                    <div class="space-y-4">
                      <!-- Project Name -->
                      <div>
                        <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Project Name</label>
                        <input x-model="argocdForm.projectName" type="text" placeholder="e.g. payments-gitops" class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm focus:ring-2 focus:ring-orange-500/20 focus:border-orange-400 outline-none transition-all">
                      </div>
                      <!-- Namespace -->
                      <div>
                        <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Base Namespace</label>
                        <input x-model="argocdForm.namespace" type="text" placeholder="e.g. payments" class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm focus:ring-2 focus:ring-orange-500/20 focus:border-orange-400 outline-none transition-all">
                        <p class="text-[10px] text-gray-400 mt-1">Apps deploy to &lt;namespace&gt;-&lt;env&gt; (e.g. payments-dev, payments-prod)</p>
                      </div>
                      <!-- Services -->
                      <div>
                        <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Services</label>
                        <template x-for="(svc, idx) in argocdForm.services" :key="idx">
                          <div class="flex items-center gap-2 mb-2">
                            <input x-model="argocdForm.services[idx]" type="text" :placeholder="'service-' + (idx+1)" class="flex-1 px-3 py-2 rounded-lg border border-gray-200 text-sm focus:ring-2 focus:ring-orange-500/20 focus:border-orange-400 outline-none transition-all font-mono">
                            <button @click="removeArgocdService(idx)" x-show="argocdForm.services.length > 1" class="p-1.5 rounded-lg hover:bg-red-50 text-gray-400 hover:text-red-500 transition-colors">
                              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                            </button>
                          </div>
                        </template>
                        <button @click="addArgocdService()" class="inline-flex items-center gap-1.5 text-[11px] font-medium text-orange-600 hover:text-orange-700 mt-1">
                          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                          Add Service
                        </button>
                        <p class="text-[10px] text-gray-400 mt-1">Each service gets its own Helm chart + per-env values</p>
                      </div>
                      <!-- Image Registry -->
                      <div>
                        <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Image Registry</label>
                        <input x-model="argocdForm.imageRegistry" type="text" placeholder="123456789.dkr.ecr.us-east-1.amazonaws.com" class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm focus:ring-2 focus:ring-orange-500/20 focus:border-orange-400 outline-none transition-all font-mono text-[12px]">
                      </div>
                      <!-- Summary -->
                      <div class="bg-orange-50 rounded-xl p-4 border border-orange-200">
                        <p class="text-[11px] font-semibold text-orange-800 mb-2">What will be generated:</p>
                        <div class="grid grid-cols-2 gap-2 text-[11px] text-orange-700">
                          <div class="flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>ArgoCD AppProject</div>
                          <div class="flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>ApplicationSet (matrix)</div>
                          <div class="flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg><span x-text="argocdForm.services.filter(s=>s.trim()).length + ' Helm chart(s)'"></span></div>
                          <div class="flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg><span x-text="argocdForm.services.filter(s=>s.trim()).length * 3 + ' ArgoCD app(s)'"></span></div>
                        </div>
                      </div>
                      <!-- Submit -->
                      <button @click="submitArgocdOnboard()" :disabled="argocdSubmitting || !argocdForm.projectName || !argocdForm.namespace || argocdForm.services.filter(s=>s.trim()).length===0" class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-sm font-bold text-white shadow-lg transition-all disabled:opacity-50 disabled:cursor-not-allowed" :class="argocdSubmitting?'bg-gray-400':'bg-orange-500 hover:bg-orange-600 shadow-orange-200 hover:shadow-orange-300'">
                        <svg x-show="argocdSubmitting" class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25"/><path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" class="opacity-75"/></svg>
                        <svg x-show="!argocdSubmitting" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>
                        <span x-text="argocdSubmitting ? 'Onboarding...' : 'Onboard to ArgoCD'"></span>
                      </button>
                    </div>
                  </div>
                  <div x-show="!argocdForm.selectedCluster" class="p-12 text-center">
                    <div class="w-16 h-16 mx-auto rounded-2xl bg-orange-50 flex items-center justify-center mb-4">
                      <svg class="w-8 h-8 text-orange-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672 13.684 16.6m0 0-2.51 2.225.569-9.47 5.227 7.917-3.286-.672ZM12 2.25V4.5m5.834.166-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.591M6 10.5H3.75m4.007-4.243-1.59-1.591"/></svg>
                    </div>
                    <p class="text-sm text-gray-400">Select an EKS cluster to configure GitOps</p>
                  </div>
                </div>
              </div>

            </div>
          </template>

          <!-- ══════ ACCOUNT DETAIL ══════ -->
          <template x-if="view==='account-detail' && accountDetail">
            <div class="fade-in space-y-6">
              <button @click="navigate('accounts')" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-brand-600 font-medium transition-colors"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>Back to Team Accounts</button>

              <div class="rounded-2xl bg-gradient-to-r from-brand-600 to-violet-600 p-6 text-white shadow-lg shadow-brand-200">
                <div class="flex justify-between items-start flex-wrap gap-4">
                  <div>
                    <h2 class="text-2xl font-bold" x-text="accountDetail.team_display_name || accountDetail.team_name"></h2>
                    <p class="text-brand-200 mt-1 font-mono text-sm" x-text="accountDetail.team_name"></p>
                    <p class="text-brand-200 text-xs mt-2" x-text="'Account: ' + (accountDetail.account_id || 'Not provisioned yet')"></p>
                  </div>
                  <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wide" :class="accountDetail.status==='active'?'bg-white/20 text-white':accountDetail.status==='pending_approval'?'bg-amber-400/30 text-amber-100':'bg-white/15 text-white/80'" x-text="accountDetail.status.replace('_',' ')"></span>
                </div>
              </div>

              <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="rounded-2xl bg-white border border-gray-200/80 shadow-sm p-6">
                  <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-4 flex items-center gap-2"><div class="w-1.5 h-4 rounded-full bg-brand-500"></div>Team Information</h3>
                  <dl class="grid grid-cols-2 gap-x-6 gap-y-4">
                    <div><dt class="text-[11px] text-gray-400 font-medium">Product Owner</dt><dd class="text-sm text-gray-900 mt-0.5" x-text="accountDetail.product_owner_email"></dd></div>
                    <div><dt class="text-[11px] text-gray-400 font-medium">Business Unit</dt><dd class="text-sm text-gray-900 mt-0.5" x-text="accountDetail.business_unit||'—'"></dd></div>
                    <div><dt class="text-[11px] text-gray-400 font-medium">Cost Center</dt><dd class="text-sm text-gray-900 mt-0.5" x-text="accountDetail.cost_center||'—'"></dd></div>
                    <div><dt class="text-[11px] text-gray-400 font-medium">Environment</dt><dd class="text-sm text-gray-900 mt-0.5" x-text="accountDetail.environment"></dd></div>
                    <div><dt class="text-[11px] text-gray-400 font-medium">Jira Ticket</dt><dd class="text-sm text-brand-600 mt-0.5 font-medium" x-text="accountDetail.jira_ticket_key||'—'"></dd></div>
                    <div><dt class="text-[11px] text-gray-400 font-medium">Created</dt><dd class="text-sm text-gray-900 mt-0.5" x-text="formatDate(accountDetail.created_at)"></dd></div>
                  </dl>
                </div>
                <div class="rounded-2xl bg-white border border-gray-200/80 shadow-sm p-6">
                  <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-4 flex items-center gap-2"><div class="w-1.5 h-4 rounded-full bg-amber-500"></div>AWS Account</h3>
                  <dl class="grid grid-cols-2 gap-x-6 gap-y-4">
                    <div><dt class="text-[11px] text-gray-400 font-medium">Account ID</dt><dd class="text-sm font-mono text-gray-900 mt-0.5" x-text="accountDetail.account_id||'Pending'"></dd></div>
                    <div><dt class="text-[11px] text-gray-400 font-medium">Account Name</dt><dd class="text-sm text-gray-900 mt-0.5" x-text="accountDetail.account_name||'—'"></dd></div>
                    <div><dt class="text-[11px] text-gray-400 font-medium">Account Email</dt><dd class="text-sm text-gray-900 mt-0.5" x-text="accountDetail.account_email||'—'"></dd></div>
                    <div><dt class="text-[11px] text-gray-400 font-medium">OU</dt><dd class="text-sm font-mono text-gray-700 mt-0.5" x-text="accountDetail.ou_id||'—'"></dd></div>
                    <div class="col-span-2"><dt class="text-[11px] text-gray-400 font-medium">OIDC Role</dt><dd class="text-xs font-mono text-gray-600 mt-0.5 break-all bg-gray-50 px-3 py-1.5 rounded-lg" x-text="accountDetail.oidc_role_arn||'Not provisioned'"></dd></div>
                    <div class="col-span-2"><dt class="text-[11px] text-gray-400 font-medium">State Bucket</dt><dd class="text-xs font-mono text-gray-600 mt-0.5 bg-gray-50 px-3 py-1.5 rounded-lg" x-text="accountDetail.state_bucket||'Not provisioned'"></dd></div>
                  </dl>
                </div>
                <div class="rounded-2xl bg-white border border-gray-200/80 shadow-sm p-6">
                  <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-4 flex items-center gap-2"><div class="w-1.5 h-4 rounded-full bg-gray-800"></div>GitHub</h3>
                  <dl class="grid grid-cols-2 gap-x-6 gap-y-4">
