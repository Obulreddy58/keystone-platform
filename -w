            <span class="text-[11px] text-gray-400">24 Terraform modules</span>
            <span class="text-gray-300">&bull;</span>
            <span class="text-[11px] text-gray-400">v4.0.0</span>
          </div>
        </footer>
      </div>

      <!-- ═══════════════════════════ COMMAND PALETTE ═══════════════════════════ -->
      <template x-if="showCommandPalette">
        <div class="fixed inset-0 z-50 flex items-start justify-center pt-[20vh]" @keydown.escape.window="showCommandPalette=false">
          <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" @click="showCommandPalette=false"></div>
          <div class="relative w-full max-w-lg bg-white rounded-2xl shadow-2xl border border-gray-200 overflow-hidden fade-in">
            <div class="flex items-center gap-3 px-5 py-4 border-b border-gray-100">
              <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/></svg>
              <input type="text" x-model="commandSearch" @input.debounce.300ms="searchCommands()" x-ref="commandInput" x-init="$nextTick(()=>$refs.commandInput?.focus())"
                     class="flex-1 border-0 focus:ring-0 text-base text-gray-800 placeholder-gray-400 bg-transparent p-0" placeholder="Search requests, teams, or actions..." />
              <kbd class="text-[10px] font-mono text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded border border-gray-200">ESC</kbd>
            </div>
            <div class="max-h-72 overflow-y-auto">
              <div x-show="commandResults.length === 0 && commandSearch.length > 0" class="px-5 py-8 text-center text-sm text-gray-400">No results found</div>
              <div x-show="commandSearch.length === 0" class="px-5 py-3">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Quick Navigation</p>
                <button @click="navigate('dashboard');showCommandPalette=false" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-700 hover:bg-brand-50 transition-colors"><svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z"/></svg>Dashboard</button>
                <button @click="navigate('requests');showCommandPalette=false" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-700 hover:bg-brand-50 transition-colors"><svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Zm3.75 11.625a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>Infrastructure Requests</button>
                <button @click="navigate('accounts');showCommandPalette=false" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-700 hover:bg-brand-50 transition-colors"><svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z"/></svg>Team Accounts</button>
                <button @click="navigate('sre');showCommandPalette=false" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-700 hover:bg-brand-50 transition-colors"><svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>SRE Onboarding</button>
                <button @click="refreshAll();showCommandPalette=false" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-700 hover:bg-brand-50 transition-colors"><svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182"/></svg>Refresh data</button>
              </div>
              <template x-for="result in commandResults" :key="result.key">
                <button @click="openDetail(result.key);showCommandPalette=false" class="w-full flex items-center gap-3 px-5 py-3 hover:bg-brand-50 transition-colors border-b border-gray-50 text-left">
                  <div class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center shrink-0">
                    <span class="text-[10px] font-mono font-bold text-gray-500" x-text="result.type.substring(0,3).toUpperCase()"></span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-gray-800 truncate" x-text="result.key + ' — ' + result.name"></p>
                    <p class="text-[11px] text-gray-400 truncate" x-text="result.team + ' · ' + result.type + ' · ' + result.status"></p>
                  </div>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold shrink-0" :class="'badge-'+result.status" x-text="result.status.replace('_',' ')"></span>
                </button>
              </template>
