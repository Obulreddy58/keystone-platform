    </div>
  </template>

  <script>
    function app() {
      return {
        // Auth state
        authenticated: false,
        user: null,
        token: null,
        loginMode: 'login',
        loginForm: { email: '', password: '' },
        registerForm: { email: '', password: '', full_name: '' },
        loginError: '',
        loginLoading: false,

        // Toast notifications
        toasts: [],

        // App state
        view: 'dashboard',
        previousView: 'dashboard',
        sidebarOpen: false,
        showCommandPalette: false,
        commandSearch: '',
        commandResults: [],
        refreshing: false,
        stats: { total_requests:0, deployed:0, pending:0, failed:0, by_type:{}, by_team:{}, by_environment:{}, recent_activity:[] },
        requests: [],
        detail: null,
        filters: { search:'', status:'', request_type:'', environment:'', team:'' },
        accounts: [],
        accountDetail: null,
        accountSearch: '',
        accountStatusFilter: '',
        accountStats: { total_accounts:0, active:0, pending_approval:0, provisioning:0, by_business_unit:{}, by_environment:{} },
        sreTeams: [],
        clusterInventory: [],
        upgradesList: [],
        latestK8sVersion: '1.32',
        upgradeForm: { selectedCluster: null, targetVersion: '', addonVersions: {}, amiType: 'AL2023_x86_64_STANDARD', strategy: 'rolling', maxUnavailable: 1, drainTimeout: 300, slackChannel: '', email: '' },
        upgradeSubmitting: false,
        argocdClusters: [],
        argocdProjects: [],
        argocdForm: { selectedCluster: null, projectName: '', namespace: '', services: [''], imageRegistry: '' },
        argocdSubmitting: false,

        get pageTitle() {
          const map = { dashboard:'Dashboard', requests:'Infrastructure Requests', accounts:'Team Accounts', sre:'SRE Onboarding', upgrades:'Cluster Upgrades', argocd:'GitOps Onboarding', 'account-detail': this.accountDetail?.team_display_name||'Account Detail', detail: this.detail?.jira_ticket_key||'Request Detail' };
          return map[this.view] || 'Keystone';
        },
        get pageSubtitle() {
          const map = { dashboard:'Infrastructure platform overview', requests:'Track and manage provisioning requests', accounts:'Manage team AWS accounts and onboarding', sre:'SRE onboarded teams and observability status', upgrades:'Kubernetes version upgrades with zero-downtime rolling updates', argocd:'Onboard services to ArgoCD with Helm charts and ApplicationSets', 'account-detail': this.accountDetail?.team_name||'', detail: this.detail ? `${this.detail.request_type} \u2022 ${this.detail.resource_name||''}` : '' };
          return map[this.view] || '';
        },

        async init() {
          // Keyboard shortcut: Ctrl+K for command palette
          document.addEventListener('keydown', (e) => {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
              e.preventDefault();
              this.showCommandPalette = !this.showCommandPalette;
              this.commandSearch = '';
              this.commandResults = [];
            }
          });

          // Check for stored session
          const storedToken = localStorage.getItem('keystone_token');
          const storedUser = localStorage.getItem('keystone_user');
          if (storedToken && storedUser) {
            try {
              const r = await fetch(`/api/auth/me?token=${encodeURIComponent(storedToken)}`);
              if (r.ok) {
                this.token = storedToken;
                this.user = JSON.parse(storedUser);
                this.authenticated = true;
                await this.loadDashboard();
              } else {
                localStorage.removeItem('keystone_token');
                localStorage.removeItem('keystone_user');
              }
            } catch(e) {
              localStorage.removeItem('keystone_token');
              localStorage.removeItem('keystone_user');
            }
          }
        },

        async loadDashboard() {
          await Promise.all([this.fetchStats(), this.fetchAccountStats()]);
          setInterval(() => { if (this.view === 'dashboard' && this.authenticated) this.fetchStats(); }, 30000);
        },

        showToast(message, type='info') {
          this.toasts.push({ message, type });
          setTimeout(() => this.toasts.shift(), 3000);
        },

        async handleLogin() {
          this.loginError = '';
          this.loginLoading = true;
          try {
            const r = await fetch('/api/auth/login', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(this.loginForm),
            });
            const data = await r.json();
            if (!r.ok) { this.loginError = data.detail || 'Login failed'; return; }
            this.token = data.access_token;
            this.user = data.user;
            localStorage.setItem('keystone_token', this.token);
            localStorage.setItem('keystone_user', JSON.stringify(this.user));
            this.authenticated = true;
            this.showToast(`Welcome back, ${this.user.full_name}!`, 'success');
            await this.loadDashboard();
          } catch(e) {
            this.loginError = 'Connection error. Please try again.';
          } finally {
            this.loginLoading = false;
          }
        },

        async handleRegister() {
          this.loginError = '';
          this.loginLoading = true;
          try {
            const r = await fetch('/api/auth/register', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(this.registerForm),
            });
            const data = await r.json();
            if (!r.ok) { this.loginError = data.detail || 'Registration failed'; return; }
            this.token = data.access_token;
            this.user = data.user;
            localStorage.setItem('keystone_token', this.token);
            localStorage.setItem('keystone_user', JSON.stringify(this.user));
            this.authenticated = true;
            this.showToast(`Account created! Welcome, ${this.user.full_name}`, 'success');
            await this.loadDashboard();
          } catch(e) {
            this.loginError = 'Connection error. Please try again.';
          } finally {
            this.loginLoading = false;
          }
        },

        logout() {
          localStorage.removeItem('keystone_token');
          localStorage.removeItem('keystone_user');
          this.token = null;
          this.user = null;
          this.authenticated = false;
          this.view = 'dashboard';
          this.sidebarOpen = false;
        },

        navigate(target) {
          this.view = target;
          this.sidebarOpen = false;
          if (target === 'requests') this.fetchRequests();
          if (target === 'accounts') this.fetchAccounts();
          if (target === 'dashboard') this.fetchStats();
          if (target === 'sre') this.fetchSreTeams();
          if (target === 'upgrades') { this.fetchClusterInventory(); this.fetchUpgrades(); }
          if (target === 'argocd') { this.fetchArgocdClusters(); this.fetchArgocdProjects(); }
        },

        async refreshAll() {
          this.refreshing = true;
          await Promise.all([this.fetchStats(), this.fetchAccountStats()]);
          if (this.view === 'sre') await this.fetchSreTeams();
          if (this.view === 'upgrades') { await this.fetchClusterInventory(); await this.fetchUpgrades(); }
          if (this.view === 'argocd') { await this.fetchArgocdClusters(); await this.fetchArgocdProjects(); }
          this.refreshing = false;
          this.showToast('Data refreshed', 'success');
        },

        async searchCommands() {
          if (!this.commandSearch.trim()) { this.commandResults = []; return; }
          try {
            const r = await fetch(`/api/requests?search=${encodeURIComponent(this.commandSearch)}&limit=8`);
            const data = await r.json();
            this.commandResults = data.map(d => ({
              key: d.jira_ticket_key,
              name: d.resource_name,
              type: d.request_type,
              team: d.team_name,
              status: d.status,
            }));
          } catch(e) { this.commandResults = []; }
        },

        async fetchSreTeams() {
          try {
            const r = await fetch('/api/requests?request_type=sre-onboarding&limit=100');
            this.sreTeams = await r.json();
          } catch(e) { console.error('SRE:', e); }
        },

        async fetchClusterInventory() {
          try {
            const r = await fetch('/api/upgrades/clusters');
            this.clusterInventory = await r.json();
          } catch(e) { console.error('Clusters:', e); }
        },

        async fetchUpgrades() {
          try {
            const r = await fetch('/api/upgrades');
            this.upgradesList = await r.json();
          } catch(e) { console.error('Upgrades:', e); }
        },

        selectClusterForUpgrade(cl) {
          if (cl.active_upgrade_key || !cl.upgrade_available) return;
          this.upgradeForm.selectedCluster = cl;
          this.upgradeForm.targetVersion = cl.next_version || '';
          this.upgradeForm.addonVersions = {};
          this.upgradeForm.amiType = cl.ami_type || 'AL2023_x86_64_STANDARD';
          this.upgradeForm.strategy = 'rolling';
          this.upgradeForm.maxUnavailable = 1;
          this.upgradeForm.drainTimeout = 300;
        },

        async submitUpgrade() {
          if (!this.upgradeForm.selectedCluster || !this.upgradeForm.targetVersion) return;
          this.upgradeSubmitting = true;
          try {
            const r = await fetch('/api/upgrades/initiate', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                source_cluster_key: this.upgradeForm.selectedCluster.jira_ticket_key,
                target_version: this.upgradeForm.targetVersion,
                upgrade_strategy: this.upgradeForm.strategy,
                node_max_unavailable: this.upgradeForm.maxUnavailable,
                drain_timeout_seconds: this.upgradeForm.drainTimeout,
                notification_slack_channel: this.upgradeForm.slackChannel,
                notification_email: this.upgradeForm.email,
              }),
            });
            const data = await r.json();
            if (!r.ok) { this.showToast(data.detail || 'Upgrade failed', 'error'); return; }
            this.showToast(`Upgrade ${data.jira_ticket_key} initiated for ${data.cluster_name}`, 'success');
            this.upgradeForm.selectedCluster = null;
            this.upgradeForm.targetVersion = '';
            await this.fetchClusterInventory();
            await this.fetchUpgrades();
          } catch(e) { this.showToast('Failed to initiate upgrade', 'error'); }
          finally { this.upgradeSubmitting = false; }
        },

        // ── ArgoCD GitOps Onboarding ─────────────────────────────────────
        async fetchArgocdClusters() {
          try { const r = await fetch('/api/argocd/clusters'); this.argocdClusters = await r.json(); } catch(e) { console.error('ArgoCD clusters:', e); }
        },

        async fetchArgocdProjects() {
          try { const r = await fetch('/api/argocd'); this.argocdProjects = await r.json(); } catch(e) { console.error('ArgoCD projects:', e); }
        },

        selectClusterForArgocd(cl) {
          if (cl.has_argocd) return;
          this.argocdForm.selectedCluster = cl;
          this.argocdForm.projectName = cl.team_name + '-gitops';
          this.argocdForm.namespace = cl.team_name;
          this.argocdForm.services = [''];
          this.argocdForm.imageRegistry = cl.account_id ? cl.account_id + '.dkr.ecr.us-east-1.amazonaws.com' : '';
        },

        addArgocdService() {
          if (this.argocdForm.services.length < 20) this.argocdForm.services.push('');
        },

        removeArgocdService(idx) {
          if (this.argocdForm.services.length > 1) this.argocdForm.services.splice(idx, 1);
        },

        async submitArgocdOnboard() {
          const svcs = this.argocdForm.services.filter(s => s.trim());
          if (!this.argocdForm.selectedCluster || !this.argocdForm.projectName || !this.argocdForm.namespace || svcs.length === 0) {
            this.showToast('Please fill all required fields and add at least one service', 'error'); return;
          }
          this.argocdSubmitting = true;
          try {
            const r = await fetch('/api/argocd/onboard', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                source_cluster_key: this.argocdForm.selectedCluster.jira_ticket_key,
                project_name: this.argocdForm.projectName,
                namespace: this.argocdForm.namespace,
                services: svcs,
                image_registry: this.argocdForm.imageRegistry,
              }),
            });
            const data = await r.json();
            if (!r.ok) { this.showToast(data.detail || 'Onboarding failed', 'error'); return; }
            this.showToast(`ArgoCD project ${data.project_name} created with ${data.total_applications} applications`, 'success');
            this.argocdForm.selectedCluster = null;
            this.argocdForm.projectName = '';
            this.argocdForm.namespace = '';
            this.argocdForm.services = [''];
            await this.fetchArgocdClusters();
            await this.fetchArgocdProjects();
          } catch(e) { this.showToast('Failed to onboard ArgoCD', 'error'); }
          finally { this.argocdSubmitting = false; }
        },

        async fetchStats() { try { const r = await fetch('/api/stats'); this.stats = await r.json(); } catch(e) { console.error('Stats:', e); } },
        async fetchAccountStats() { try { const r = await fetch('/api/accounts/stats'); this.accountStats = await r.json(); } catch(e) { console.error('AcctStats:', e); } },

        async fetchRequests() {
          const p = new URLSearchParams();
          if (this.filters.search) p.set('search', this.filters.search);
          if (this.filters.status) p.set('status', this.filters.status);
          if (this.filters.request_type) p.set('request_type', this.filters.request_type);
          if (this.filters.environment) p.set('environment', this.filters.environment);
          try { const r = await fetch(`/api/requests?${p}`); this.requests = await r.json(); } catch(e) { console.error('Requests:', e); }
        },

        async openDetail(jiraKey) {
          this.previousView = this.view;
          try { const r = await fetch(`/api/requests/${encodeURIComponent(jiraKey)}`); this.detail = await r.json(); this.view = 'detail'; } catch(e) { console.error('Detail:', e); }
        },

        async fetchAccounts() {
          const p = new URLSearchParams();
          if (this.accountSearch) p.set('search', this.accountSearch);
          if (this.accountStatusFilter) p.set('status', this.accountStatusFilter);
          try { const [a,s] = await Promise.all([fetch(`/api/accounts?${p}`), fetch('/api/accounts/stats')]); this.accounts = await a.json(); this.accountStats = await s.json(); } catch(e) { console.error('Accounts:', e); }
        },

        async openAccountDetail(teamName) {
          try { const r = await fetch(`/api/accounts/${encodeURIComponent(teamName)}`); this.accountDetail = await r.json(); this.view = 'account-detail'; } catch(e) { console.error('AcctDetail:', e); }
        },

        async approveAccount(teamName) {
          try {
            await fetch(`/api/accounts/${encodeURIComponent(teamName)}/approve`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({approved:true, approved_by:this.user?.email || 'admin'}) });
            this.showToast(`Account '${teamName}' approved`, 'success');
            await this.fetchAccounts();
            if (this.accountDetail?.team_name === teamName) await this.openAccountDetail(teamName);
          } catch(e) { this.showToast('Failed to approve account', 'error'); }
        },

        async rejectAccount(teamName) {
          const reason = prompt('Reason for rejection:') || '';
          try {
            await fetch(`/api/accounts/${encodeURIComponent(teamName)}/approve`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({approved:false, approved_by:this.user?.email || 'admin', reason}) });
            this.showToast(`Account '${teamName}' rejected`, 'error');
            await this.fetchAccounts();
          } catch(e) { this.showToast('Failed to reject account', 'error'); }
        },

        formatDate(iso) {
          if (!iso) return '—';
          const d = new Date(iso);
          return d.toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'})+' '+d.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
        }
      };
    }
  </script>
</body>
</html>
